{"compilerOptions":{
    "target":"ES2020",
    "module":"ESNext",
    "moduleResolution":"bundler",
    "ignoreDeprecations":"6.0",
    "lib":["ES2020","DOM"],
    "allowJs":true,
    "checkJs":false,
    
    "outDir": "dist/client",
    "rootDir": "../",
    "declaration": true,
    "sourceMap":true,
    "noEmit":false,

    "strict":true,
    "noImplicitAny":true,
    "forceConsistentCasingInFileNames":true,

    "esModuleInterop":true,
    "allowSyntheticDefaultImports":true,
    "resolveJsonModule":true,

    "skipLibCheck":true,
    "incremental":true,
    "types":["node"]
  },
  "include": [
    "../FlowChat/src/client/**/*.ts",
  ],
  "exclude": [
    "../FlowChat/src/__test__/**/*.ts",
    "../FlowChat/src/server/**/*.ts",
    "../FlowChat/node_modules",
    "../FlowChat/coverage",                 // ✅ exclude generated coverage output
    "../FlowChat/dist",
  ]
}